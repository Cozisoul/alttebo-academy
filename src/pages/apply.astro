---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Apply Now">
	<Header />
	<section class="max-w-2xl mx-auto px-6 py-24">
		<h1 class="text-4xl font-display font-bold text-slate-900 mb-6">Student Registration</h1>
		<p class="text-slate-600 mb-12">Please fill in your details below and click submit. Your default email app will open with a pre-filled application to send to our admissions team.</p>

		<form id="application-form" class="space-y-6 bg-white p-8 rounded-xl shadow-sm border border-gray-100">
			<div>
				<label class="block text-sm font-bold text-slate-700 mb-2" for="full-name">Full Name</label>
				<input id="full-name" type="text" required class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-alttebo-blue focus:border-alttebo-blue" placeholder="John Doe" />
			</div>

			<div>
				<label class="block text-sm font-bold text-slate-700 mb-2" for="phone">Phone Number (WhatsApp)</label>
				<input id="phone" type="tel" required class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-alttebo-blue" placeholder="082 123 4567" />
			</div>

			<div>
				<label class="block text-sm font-bold text-slate-700 mb-2" for="course">Interested Course</label>
				<select id="course" class="w-full p-3 border border-gray-300 rounded-lg bg-white">
					<option>Automotive Body Repair (Panel Beating)</option>
					<option>Automotive Spray Painting</option>
				</select>
			</div>

			<div>
				<label class="block text-sm font-bold text-slate-700 mb-2" for="grade">Highest Grade Passed</label>
				<select id="grade" class="w-full p-3 border border-gray-300 rounded-lg bg-white">
					<option>Grade 9</option>
					<option>Grade 10</option>
					<option>Grade 11</option>
					<option>Grade 12 (Matric)</option>
					<option>N2 Certificate</option>
				</select>
			</div>

			<button type="submit" class="w-full bg-alttebo-blue text-white font-bold py-4 rounded-lg hover:bg-alttebo-dark transition-colors uppercase tracking-wide mt-4">
				Submit Application
			</button>
		</form>
	</section>
	<Footer />
</Layout>

<script>
	const form = document.getElementById('application-form');

	form?.addEventListener('submit', (e) => {
		e.preventDefault();

		const name = (document.getElementById('full-name') as HTMLInputElement).value;
		const phone = (document.getElementById('phone') as HTMLInputElement).value;
		const course = (document.getElementById('course') as HTMLSelectElement).value;
		const grade = (document.getElementById('grade') as HTMLSelectElement).value;

		const subject = encodeURIComponent(`New Student Application – ${name}`);
		const body = encodeURIComponent(
			`Dear Alttebo Training Academy,\n\n` +
			`I would like to apply for training at Alttebo Academy.\n\n` +
			`Full Name: ${name}\n` +
			`Phone / WhatsApp: ${phone}\n` +
			`Course: ${course}\n` +
			`Highest Grade Passed: ${grade}\n\n` +
			`Please contact me regarding fees and start dates.\n\n` +
			`Kind regards,\n${name}`
		);

		window.location.href = `mailto:office@alttebo.com?subject=${subject}&body=${body}`;
	});
</script>
